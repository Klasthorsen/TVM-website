---
const logos = [
  { src: "https://www.figma.com/api/mcp/asset/ec39e47d-3c47-43cf-aad4-6d0a388c9409", alt: "Partner logo 1" },
  { src: "https://www.figma.com/api/mcp/asset/20ee04a5-2fad-4f36-8380-44e97dfe4008", alt: "Partner logo 2" },
  { src: "https://www.figma.com/api/mcp/asset/5be98e67-30d1-4936-b475-41178b8fd2cd", alt: "Partner logo 3" },
  { src: "https://www.figma.com/api/mcp/asset/eea068dd-9874-4cde-99dd-a81a00ec18a4", alt: "Partner logo 4" },
  { src: "https://www.figma.com/api/mcp/asset/72f4e2fe-231e-40c0-b5e0-0ccfe6143ac8", alt: "Partner logo 5" },
  { src: "https://www.figma.com/api/mcp/asset/befa5117-06bc-4eb2-84b6-de916d0518ac", alt: "Partner logo 6" },
];
---

<section class="w-full max-w-[1500px] mx-auto px-10 py-12">
  <p class="font-body text-[15px] text-dark-grey tracking-[-0.075px] mb-8">
    Trusted by:
  </p>
  <div class="flex flex-wrap justify-center gap-5 md:gap-10">
    {
      logos.map((logo) => (
        <div class="w-[114px] h-[44px] opacity-60 mix-blend-exclusion">
          <img
            src={logo.src}
            alt={logo.alt}
            class="w-full h-full object-contain"
          />
        </div>
      ))
    }
  </div>
</section>
