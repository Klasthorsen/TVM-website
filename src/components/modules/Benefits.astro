---
interface Props {
  label: string;
  headline: string;
  subheadline: string;
  image: string;
  items: Array<{ title: string; description: string; icon: string }>;
}

const { label, headline, subheadline, image, items } = Astro.props;
---

<section id="benefits" class="w-full max-w-[1500px] mx-auto px-10 pb-32">
  <div class="border-t border-divider pt-20 pb-16">
    <div class="max-w-[800px]">
      <span class="font-mono text-xs text-accent tracking-[-0.12px] uppercase mb-4 block">{label}</span>
      <h2 class="font-display text-[36px] md:text-[60px] leading-[0.9] tracking-[-1.8px] mt-16">{headline}</h2>
      <p class="font-body text-[15px] text-dark-grey tracking-[-0.075px] mt-12">{subheadline}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-12">
      {items.map((benefit) => (
        <article class="border-t border-divider pt-10 pb-10 pr-5">
          <div class="w-6 h-6 mb-6">
            {benefit.icon === "cable" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 20h4m-2-2v-4m14 0v-4m0-2V4m-4 4h4m-4 8h4M8 4h8v4H8V4zm0 12h8v4H8v-4z" />
              </svg>
            )}
            {benefit.icon === "earth" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                <path d="M2 12h20" />
              </svg>
            )}
            {benefit.icon === "account" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            )}
            {benefit.icon === "chart" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 3v18h18" />
                <path d="M18 9l-5 5-4-4-4 4" />
              </svg>
            )}
          </div>
          <h3 class="font-display text-lg tracking-[-0.54px] mb-5">{benefit.title}</h3>
          <p class="font-body text-[15px] text-dark-grey tracking-[-0.075px] leading-[1.4]">{benefit.description}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="h-[400px] md:h-[620px] rounded-[30px] overflow-hidden">
    <img src={image} alt="Benefits section hero" class="w-full h-full object-cover" />
  </div>
</section>
