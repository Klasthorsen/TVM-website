---
interface Props {
  headline?: string;
  content: string;
  centered?: boolean;
}

const { headline, content, centered = false } = Astro.props;
---

<section class={`w-full max-w-[1500px] mx-auto px-10 py-16 ${centered ? 'text-center' : ''}`}>
  {headline && (
    <h2 class="font-display text-[36px] md:text-[60px] leading-[0.9] tracking-[-1.8px] mb-8">{headline}</h2>
  )}
  <div class="prose prose-lg max-w-none font-body text-dark-grey" set:html={content} />
</section>
