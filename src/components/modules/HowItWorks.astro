---
interface Props {
  headline: string;
  steps: Array<{ title: string; description: string }>;
}

const { headline, steps } = Astro.props;
---

<section id="how-to" class="w-full max-w-[1500px] mx-auto px-10 pb-32">
  <div class="border-t border-divider pt-20">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-20">
      <h2 class="font-display text-[36px] md:text-[60px] leading-[0.9] tracking-[-1.8px]">{headline}</h2>
      <a href="#contact" class="bg-accent-light font-body font-bold text-sm tracking-[-0.35px] px-[22px] py-[14px] rounded-full hover:bg-accent-light/80 transition-colors">
        Discover More
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {steps.map((step, index) => (
        <article class="border-t border-divider pt-16 pb-5 pr-8">
          <span class="font-body text-[60px] md:text-[80px] leading-none tracking-[-3.2px] text-light-grey">
            {String(index + 1).padStart(2, "0")}
          </span>
          <div class="mt-16">
            <h3 class="font-display text-lg tracking-[-0.54px]">{step.title}</h3>
            <p class="font-body text-[15px] text-dark-grey tracking-[-0.075px] mt-5 leading-[1.4]">{step.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
