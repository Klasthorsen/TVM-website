---
const navItems = [
  { label: "Benefits", href: "#benefits" },
  { label: "Specifications", href: "#specifications" },
  { label: "How-to", href: "#how-to" },
];

const logoSvg = "https://www.figma.com/api/mcp/asset/e95af478-f4e2-4833-959d-f6a9747b63c3";
---

<footer class="w-full max-w-[1500px] mx-auto px-10 border-t border-divider pt-10 pb-5">
  <div class="flex items-center justify-between h-10 mb-20">
    <nav class="flex gap-7">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="font-body font-bold text-sm tracking-[-0.35px] hover:text-accent transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>

  <div class="flex flex-col md:flex-row items-end gap-10">
    <div class="h-[70px] w-8">
      <img src={logoSvg} alt="Area logo" class="h-full w-full object-contain" />
    </div>

    <div class="flex-1 flex items-center gap-4 font-mono text-xs text-accent tracking-[-0.12px]">
      <span>© Area.</span>
      <span>2025</span>
    </div>

    <span class="font-mono text-xs text-accent tracking-[-0.12px]">
      All Rights Reserved
    </span>
  </div>
</footer>
