---
interface Props {
  settings: {
    siteName: string;
    navigation: Array<{ label: string; href: string }>;
    footer: {
      copyright: string;
      year: string;
    };
  };
}

const { settings } = Astro.props;
---

<footer class="w-full max-w-[1500px] mx-auto px-10 border-t border-divider pt-10 pb-5">
  <div class="flex items-center justify-between h-10 mb-20">
    <nav class="flex gap-7">
      {settings.navigation.slice(0, 3).map((item) => (
        <a href={item.href} class="font-body font-bold text-sm tracking-[-0.35px] hover:text-accent transition-colors">
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="flex flex-col md:flex-row items-end gap-10">
    <div class="font-body font-medium text-[30px] tracking-[-1.5px]">
      {settings.siteName}
    </div>

    <div class="flex-1 flex items-center gap-4 font-mono text-xs text-accent tracking-[-0.12px]">
      <span>{settings.footer.copyright}</span>
      <span>{settings.footer.year}</span>
    </div>

    <span class="font-mono text-xs text-accent tracking-[-0.12px]">
      All Rights Reserved
    </span>
  </div>
</footer>
