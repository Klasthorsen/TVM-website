---
const testimonialImage = "https://www.figma.com/api/mcp/asset/6b47232a-48ae-42df-b481-b5599f2f314c";
---

<section class="w-full max-w-[1500px] mx-auto px-10 pb-32">
  <div class="flex flex-col md:flex-row gap-5 h-auto md:h-[670px]">
    <div class="flex-1 rounded-[30px] overflow-hidden">
      <img
        src={testimonialImage}
        alt="Concrete sphere balanced between two larger spheres"
        class="w-full h-[300px] md:h-full object-cover"
      />
    </div>

    <div class="flex-1 border-t border-divider flex flex-col justify-center pl-0 md:pl-12 py-10">
      <blockquote class="font-display text-[24px] md:text-[40px] leading-none tracking-[-1.6px]">
        "I was skeptical, but Area has completely transformed the way I manage
        my business. The data visualizations are so clear and intuitive, and the
        platform is so easy to use. I can't imagine running my company without
        it."
      </blockquote>

      <div class="mt-12">
        <p class="font-body text-[15px] tracking-[-0.075px]">John Smith</p>
        <p class="font-mono text-xs text-accent tracking-[-0.12px] mt-2">
          Head of Data
        </p>
      </div>
    </div>
  </div>
</section>
