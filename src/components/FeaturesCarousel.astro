---
const features = [
  { num: "01", text: "Spot Trends in Seconds: No more digging through numbers." },
  {
    num: "02",
    text: "Get Everyone on the Same Page: Share easy-to-understand reports with your team.",
  },
  {
    num: "03",
    text: "Make Presentations Pop: Interactive maps and dashboards keep your audience engaged.",
  },
  {
    num: "04",
    text: "Your Global Snapshot: Get a quick, clear overview of your entire operation.",
  },
];

const featureImage = "https://www.figma.com/api/mcp/asset/a4abd79a-ead6-46b9-be31-fb6d5d22dc3d";
---

<section class="w-full max-w-[1500px] mx-auto px-10 pb-32">
  <div class="flex flex-col lg:flex-row gap-5">
    <div class="flex-1 border-t border-divider pt-16 pb-20">
      <div class="max-w-[510px]">
        <h2 class="font-display text-[36px] md:text-[60px] leading-[0.9] tracking-[-1.8px]">
          See the Big Picture
        </h2>
        <p class="font-body text-[15px] text-dark-grey tracking-[-0.075px] mt-10">
          Area turns your data into clear, vibrant visuals that show you exactly
          what's happening in each region.
        </p>
      </div>

      <div class="mt-10">
        {
          features.map((feature) => (
            <article class="border-t border-divider flex gap-8 py-5 pr-20">
              <span class="font-body font-bold text-[15px] text-dark-grey tracking-[-0.075px]">
                {feature.num}
              </span>
              <p class="font-body text-[15px] tracking-[-0.075px]">
                {feature.text}
              </p>
            </article>
          ))
        }
      </div>

      <a
        href="#"
        class="inline-block bg-accent-light font-body font-bold text-sm tracking-[-0.35px] px-[22px] py-[14px] rounded-full hover:bg-accent-light/80 transition-colors mt-10"
      >
        Discover More
      </a>
    </div>

    <div class="flex-1">
      <div class="h-[400px] lg:h-[711px] rounded-[30px] overflow-hidden relative">
        <img
          src={featureImage}
          alt="Three white cylindrical columns"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/5 rounded-[30px]"></div>
      </div>
    </div>
  </div>
</section>
