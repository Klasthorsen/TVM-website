---
interface Props {
  data: {
    title: string;
    heroImage: string;
  };
}

const { data } = Astro.props;
---

<header class="w-full max-w-[1500px] mx-auto px-10">
  <h1
    class="font-display text-[60px] md:text-[100px] lg:text-[160px] leading-[0.9] tracking-[-3px] md:tracking-[-6.8px] text-center"
  >
    {data.title}
  </h1>

  <div class="mt-16 md:mt-60 relative">
    <div
      class="bg-mid-green h-[250px] md:h-[362px] rounded-[30px] w-full relative overflow-visible"
    >
      <div
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] md:w-[907px] h-[400px] md:h-[644px] bg-black rounded-[24px] border-t-2 border-l-2 border-r-2 border-white/50 shadow-[0px_-4px_20px_0px_rgba(0,0,0,0.1)] overflow-hidden"
      >
        <div class="absolute inset-4 rounded-[16px] overflow-hidden">
          <img
            src={data.heroImage}
            alt="Data visualization"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</header>
