---
import seoData from "../content/seo.json";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const { 
  title, 
  description, 
  ogImage,
  noIndex = false 
} = Astro.props;

const seo = seoData.global;
const og = seoData.openGraph;
const twitter = seoData.twitter;
const business = seoData.localBusiness;
const advanced = seoData.advanced;

const pageTitle = title 
  ? `${title} ${seo.titleSeparator} ${seo.siteTitle}` 
  : seo.siteTitle;
const pageDescription = description || seo.metaDescription;
const pageOgImage = ogImage || og.ogImage;
const robots = noIndex ? "noindex, nofollow" : seo.robots;

const structuredData = business.enabled ? {
  "@context": "https://schema.org",
  "@type": business.type,
  "name": business.name,
  "description": business.description,
  "logo": business.logo ? `${seo.canonicalUrl}${business.logo}` : undefined,
  "url": seo.canonicalUrl,
  "telephone": business.phone || undefined,
  "email": business.email || undefined,
  "address": business.streetAddress ? {
    "@type": "PostalAddress",
    "streetAddress": business.streetAddress,
    "addressLocality": business.city,
    "postalCode": business.postalCode,
    "addressRegion": business.region,
    "addressCountry": business.country
  } : undefined,
  "geo": business.latitude && business.longitude ? {
    "@type": "GeoCoordinates",
    "latitude": business.latitude,
    "longitude": business.longitude
  } : undefined,
  "openingHours": business.openingHours?.map((h: any) => `${h.days} ${h.hours}`),
  "sameAs": business.socialProfiles?.map((p: any) => p.url)
} : null;
---

<!doctype html>
<html lang={seo.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={seo.metaKeywords} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={seo.canonicalUrl} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={og.ogType} />
    <meta property="og:url" content={seo.canonicalUrl} />
    <meta property="og:title" content={og.ogTitle || pageTitle} />
    <meta property="og:description" content={og.ogDescription || pageDescription} />
    {pageOgImage && <meta property="og:image" content={pageOgImage.startsWith('http') ? pageOgImage : `${seo.canonicalUrl}${pageOgImage}`} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content={twitter.cardType} />
    <meta name="twitter:url" content={seo.canonicalUrl} />
    <meta name="twitter:title" content={og.ogTitle || pageTitle} />
    <meta name="twitter:description" content={og.ogDescription || pageDescription} />
    {(twitter.twitterImage || pageOgImage) && <meta name="twitter:image" content={(twitter.twitterImage || pageOgImage).startsWith('http') ? (twitter.twitterImage || pageOgImage) : `${seo.canonicalUrl}${twitter.twitterImage || pageOgImage}`} />}
    {twitter.twitterHandle && <meta name="twitter:site" content={twitter.twitterHandle} />}
    
    <!-- Verification -->
    {advanced.googleVerification && <meta name="google-site-verification" content={advanced.googleVerification} />}
    {advanced.bingVerification && <meta name="msvalidate.01" content={advanced.bingVerification} />}
    
    <!-- Google Analytics -->
    {advanced.googleAnalyticsId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${advanced.googleAnalyticsId}`}></script>
        <script define:vars={{ gaId: advanced.googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    
    <!-- Google Tag Manager -->
    {advanced.gtmId && (
      <script define:vars={{ gtmId: advanced.gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
    
    <!-- Structured Data -->
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&family=Roboto+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    
    <!-- Custom Head Code -->
    {advanced.customHeadCode && <Fragment set:html={advanced.customHeadCode} />}
  </head>
  <body class="bg-white text-black antialiased">
    {advanced.gtmId && (
      <noscript>
        <iframe src={`https://www.googletagmanager.com/ns.html?id=${advanced.gtmId}`} height="0" width="0" style="display:none;visibility:hidden"></iframe>
      </noscript>
    )}
    <slot />
  </body>
</html>
